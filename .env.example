# DB (misma que core-api)
DATABASE_URL=postgresql://...pooler...

# JWT (mismo secret que core-api para compatibilidad)
JWT_SECRET=...
JWT_EXPIRES_IN=7d

# Meta (opcional si solo registras eventos y no verificas webhook real de Meta)
META_VERIFY_TOKEN=...
META_ACCESS_TOKEN=...

# Twilio (opcional)
TWILIO_ACCOUNT_SID=...
TWILIO_AUTH_TOKEN=...

# Comunicacion entre servicios (opcional si no llamas a core-api / ai-api)
SERVICE_TOKEN=...
CORE_API_URL=https://api.mesonbots.com
AI_API_URL=https://ai.mesonbots.com

# CORS (que frontends pueden llamarlo)
CORS_ORIGINS=https://app.mesonbots.com,http://localhost:4200

# Config
NODE_ENV=production
PORT=3000
